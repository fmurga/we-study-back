# Database — PostgreSQL runs via Docker only
# Start with: pnpm docker:up
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/we_study"

# Typesense — also runs via Docker only
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=we-study-api-key

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-strong-random-secret

# App
PORT=5000
NODE_ENV=development

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
